{% set resolved_l1_profile =
  'internal-lean' if l1_org_docs_profile == 'compact' and l2_org_docs_default == 'compact' and not enable_community_pack and not enable_release_pack and not enable_vouch_gate
  else 'internal-standard' if l1_org_docs_profile == 'rich' and l2_org_docs_default == 'compact' and not enable_community_pack and not enable_release_pack and not enable_vouch_gate
  else 'internal-governed' if l1_org_docs_profile == 'rich' and l2_org_docs_default == 'compact' and not enable_community_pack and enable_release_pack and not enable_vouch_gate
  else 'public-collaboration' if l1_org_docs_profile == 'rich' and l2_org_docs_default == 'compact' and enable_community_pack and enable_release_pack and not enable_vouch_gate
  else 'public-trust-gated' if l1_org_docs_profile == 'rich' and l2_org_docs_default == 'compact' and enable_community_pack and enable_release_pack and enable_vouch_gate
  else 'public-rich-org' if l1_org_docs_profile == 'rich' and l2_org_docs_default == 'rich' and enable_community_pack and enable_release_pack and enable_vouch_gate
  else 'custom'
%}
schema: ai-society.template-provenance.v1
template:
  profile: "{{ resolved_l1_profile }}"
  source_repository: "core/tpl-template-repo"
  source_sha: "{{ l0_source_sha }}"
render:
  repo_slug: "{{ repo_slug }}"
  layer: L1
  answers_file: ".copier-answers.yml"
  content_hash_sha256: "__RENDER_HASH__"
