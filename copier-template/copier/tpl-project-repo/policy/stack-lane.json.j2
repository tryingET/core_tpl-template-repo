{%- if enable_software_pack and language in ["python", "node", "typescript", "go", "rust", "elixir"] -%}
{
  "lane": "{{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}",
  "tech_stack_core": {
    "tool": "tech-stack-core",
    "lane": "{{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}",
    "repository": "https://github.com/lightningralf/tech-stack-core",
    "ref": "workspace-local-unpinned",
    "command": "uv tool run --from ~/ai-society/core/tech-stack-core tech-stack-core show {{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}"
  }
}
{%- endif -%}
