schema: ai-society.template-provenance.v1
template:
  profile: template-repo
  source_repository: "l1-template/copier/template-repo"
  source_sha: "{{ template_source_sha }}"
render:
  repo_slug: "{{ repo_slug }}"
  archetype: "{{ repo_archetype }}"
  answers_file: ".copier-answers.yml"
  content_hash_sha256: "__RENDER_HASH__"
