{%- if enable_software_pack and language in ["python", "node", "typescript", "go", "rust", "elixir"] -%}
{
  "lane": "{{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}",
  "engineering_core": {
    "tool": "engineering-core",
    "lane": "{{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}",
    "repository": "https://github.com/lightningralf/engineering-core",
    "ref": "workspace-local-unpinned",
    "command": "uv tool -n run --from ~/ai-society/core/engineering-core engineering-core show {{ "py" if language == "python" else "go" if language == "go" else "rust" if language == "rust" else "elixir" if language == "elixir" else "ts" }}"
  }
}
{%- endif -%}
